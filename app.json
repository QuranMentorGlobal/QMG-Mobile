{
  "expo": {
    "name": "QMG",
    "slug": "qmg-mobile",
    "scheme": "qmgmobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quranmentorglobal.app"
    },
    "android": {
      "package": "com.quranmentorglobal.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#111111"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QMG needs access to your photos so you can share images in chat."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "QMG needs microphone access so you can record voice notes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/93a7329d-2b4a-4272-8b00-8812513e4722"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "93a7329d-2b4a-4272-8b00-8812513e4722"
      }
    }
  }
}